{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; img-src 'self' data:; connect-src 'self' https://*.cloudantnosqldb.appdomain.cloud; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
          }
        ]
      },
      {
        "source": "/@(sw.js|sw-precache.js)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
