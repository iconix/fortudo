#!/bin/bash

# Source NVM if it exists.
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

# Add common npm locations to PATH (Windows and Unix).
export PATH="$PATH:$HOME/AppData/Roaming/npm:/c/Program Files/nodejs:$HOME/.nvm/versions/node/$(node -v 2>/dev/null)/bin"

echo "Running staged-file pre-commit checks..."

STAGED_FILES=$(git diff --cached --name-only --diff-filter=d)
RELEVANT_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx|json|md|py|toml|ya?ml)$' || true)

if [ -z "$RELEVANT_FILES" ]; then
    echo "No relevant files staged for commit. Skipping checks."
    exit 0
fi

JS_AND_DOC_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx|json|md)$' || true)
JS_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(js|jsx|ts|tsx)$' || true)
PYTHON_AND_CONFIG_FILES=$(printf '%s\n' "$STAGED_FILES" | grep -E '\.(py|toml|ya?ml)$' || true)

# Hash staged content, not only path names, so checks cannot silently change the commit.
HASH_BEFORE=$(git diff --cached | sha1sum)

if ! command -v npm &> /dev/null; then
    echo "npm command not found. Please ensure Node.js is installed and in your PATH."
    exit 1
fi

if [ -n "$JS_AND_DOC_FILES" ]; then
    echo "Running JavaScript linting and formatting checks..."
    npm run check || exit 1
fi

if [ -n "$JS_FILES" ]; then
    echo "Running Jest tests related to staged JavaScript..."
    # Repository paths do not contain whitespace; intentional word splitting passes each path to Jest.
    # shellcheck disable=SC2086
    npm test -- --findRelatedTests $JS_FILES --runInBand --passWithNoTests || exit 1
fi

if [ -n "$PYTHON_AND_CONFIG_FILES" ]; then
    echo "Running Python linting and non-browser tests..."
    npm run lint:python || exit 1
    npm run test:python || exit 1
fi

HASH_AFTER=$(git diff --cached | sha1sum)

if [ "$HASH_BEFORE" != "$HASH_AFTER" ]; then
    echo "Files were modified during pre-commit checks. Stage the changes and try again."
    exit 1
fi

echo "All pre-commit checks passed!"
exit 0
